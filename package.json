{
  "name": "grl",
  "version": "1.0.0",
  "description": "Reusable feature, evidence, circuit, and relation graph explorer",
  "type": "module",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/akfldk1028/GRL.git" },
  "homepage": "https://akfldk1028.github.io/GRL/",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./styles.css": "./dist/styles.css",
    "./schema.json": "./schema/grl-v1.schema.json"
  },
  "bin": { "grl": "./dist/cli.js" },
  "files": ["dist", "dist-app", "schema", "README.md", "LICENSE"],
  "sideEffects": ["*.css"],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build:lib": "tsup src/index.ts src/cli.ts --format esm --dts --clean --splitting false && node scripts/copy-style.mjs",
    "build:app": "vite build",
    "build": "npm run build:lib && npm run build:app",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "playwright test --reporter=line",
    "verify": "npm run typecheck && npm run test && npm run build && npm run smoke && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": { "zod": "^3.23.8" },
  "peerDependencies": { "react": ">=18", "react-dom": ">=18" },
  "overrides": { "esbuild": "^0.28.1" },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.17.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.1",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
