{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"], "jsx": "react-jsx", "strict": true,
    "esModuleInterop": true, "skipLibCheck": true, "resolveJsonModule": true,
    "declaration": true, "types": ["node", "vite/client"]
  },
  "include": ["src", "app", "tests", "vite.config.ts", "playwright.config.ts"]
}
